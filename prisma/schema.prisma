// ============================================================
// Prisma スキーマ — チョコット先生
// ------------------------------------------------------------
// 仕様書に基づく本設計。認証は Credentials(メール/パスワード) +
// JWT 方式を採用するため、NextAuth のアダプタ用テーブル
// (Account / Session) は不要としています。
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enum 定義
// ============================================================

/// ユーザーロール（生徒 / 先生 / 管理者）
enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

/// 先生プロフィールの審査ステータス
enum ProfileStatus {
  DRAFT // 下書き（作成途中）
  PENDING // 公開申請中（管理者の承認待ち）
  APPROVED // 承認済み
  REJECTED // 却下
}

/// 対応レベル（レッスンで対応できる習熟度）
enum SkillLevel {
  BEGINNER // 初級
  INTERMEDIATE // 中級
  ADVANCED // 上級
}

/// 対象年齢層（指導対象）
enum TargetAge {
  PRESCHOOL // 幼児・未就学児
  ELEMENTARY // 小学生
  JUNIOR_HIGH // 中学生
  HIGH_SCHOOL // 高校生
  UNIVERSITY // 大学生・専門学生
  ADULT // 社会人・一般
  SENIOR // シニア
}

/// 先生の性別（任意）
enum Gender {
  MALE // 男性
  FEMALE // 女性
  OTHER // その他
  NO_ANSWER // 回答しない
}

/// 先生の年代（任意・プライバシーに配慮して年代で保持）
enum AgeRange {
  TEENS // 10代
  TWENTIES // 20代
  THIRTIES // 30代
  FORTIES // 40代
  FIFTIES // 50代
  SIXTIES_PLUS // 60代以上
}

/**
 * 指導方法（複数選択可・将来の追加もこの enum に足す）
 * BOTH は旧単一選択の互換用。新規保存では使わない。
 */
enum TeachingMethod {
  IN_PERSON // 対面
  ONLINE // オンライン
  PHONE // 電話
  BOTH // 旧「両方」（IN_PERSON+ONLINE 相当・レガシー）
}

/// レビューの審査ステータス
enum ReviewStatus {
  PENDING // 審査待ち
  APPROVED // 公開
  REJECTED // 非公開
}

/// 決済方法
enum PaymentMethod {
  PAYPAL // PayPal（即時反映）
  BANK_TRANSFER // 銀行振込（管理者確認後に開放）
}

/// 連絡先購入のステータス
enum PurchaseStatus {
  PENDING // 未完了（振込待ちなど）
  COMPLETED // 完了（連絡先開放済み）
  FAILED // 失敗
  REFUNDED // 返金
}

/// お問い合わせの対応ステータス
enum InquiryStatus {
  NEW // 新規
  REPLIED // 返信済み
  CLOSED // 対応完了
}

/// 本人確認書類の種類
enum IdentityDocumentType {
  ID_CARD // マイナンバーカード・住民基本台帳カード等
  DRIVERS_LICENSE // 運転免許証
  PASSPORT // パスポート
}

/// 本人確認申請レコード側の審査ステータス（IdentityVerification.status）
enum VerificationStatus {
  PENDING // 審査待ち
  APPROVED // 承認
  REJECTED // 却下
}

/**
 * TeacherProfile に保持する本人確認の集約ステータス（高速表示・検索用）
 *
 * IdentityVerification（書類申請）の結果をここに同期する。
 * 将来メール認証・電話番号認証などを追加する場合は、別チャネルの結果を
 * 集約するか、TeacherAuthFactor 等のテーブルを追加して拡張する。
 */
enum IdentityVerificationStatus {
  PENDING // 審査待ち
  VERIFIED // 本人確認済み
  REJECTED // 差し戻し
}

/// 通知の種類（将来の拡張に備え汎用的に定義）
enum NotificationType {
  SYSTEM // システムからのお知らせ
  PROFILE_APPROVED // プロフィール承認
  PROFILE_REJECTED // プロフィール却下
  VERIFICATION_RESULT // 本人確認の結果
  NEW_PURCHASE // 連絡先が購入された（先生向け）
  NEW_REVIEW // 新しいレビュー
  NEW_CONSULTATION // 事前相談が届いた（先生向け）
  CONSULTATION_REPLY // 事前相談の返信（生徒向け）
}

/// 会話の種類（事前相談 → 将来のチャットへ拡張可能）
enum ConversationType {
  PRE_CONSULTATION // 事前相談（無料往復制限あり）
  CHAT // 将来の通常チャット
}

/// 会話スレッドの状態
enum ConversationStatus {
  OPEN // やり取り可能
  LOCKED // 無料枠終了（連絡先購入で再開可）
  CLOSED // 終了
}

/// メッセージ送信者の役割
enum MessageSenderRole {
  STUDENT
  TEACHER
  SYSTEM
}

/// メッセージ種別（将来の画像・システムメッセージ拡張用）
enum MessageKind {
  TEXT
  SYSTEM
}

/// NGワードのカテゴリ
enum NgWordCategory {
  CONTACT_EXCHANGE // 連絡先交換
  SOLICITATION // 勧誘・詐欺防止
  CUSTOM // 管理者が追加した任意ワード
}

/// 通報の対応ステータス
enum ReportStatus {
  NEW // 未対応
  REVIEWING // 対応中
  RESOLVED // 対応完了
  DISMISSED // 対応不要
}

// ============================================================
// ユーザー
// ============================================================

/// 共通ユーザー（生徒 / 先生 / 管理者を role で区別）
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(STUDENT)
  emailVerified DateTime? @map("email_verified") // メール認証が完了した日時（未認証は null）
  lastLoginAt   DateTime? @map("last_login_at") // 最終ログイン日時
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // --- リレーション ---
  teacherProfile TeacherProfile? // 先生の場合のプロフィール
  studentProfile StudentProfile? // 生徒の場合のプロフィール
  purchases      Purchase[] // この生徒が行った連絡先購入
  reviews        Review[] // この生徒が投稿したレビュー
  favorites      Favorite[] // この生徒のお気に入り
  recentlyViewed RecentlyViewed[] // この生徒が最近見た先生
  notifications  Notification[] // この生徒/先生宛の通知
  passwordResetTokens PasswordResetToken[] // パスワード再設定トークン
  conversationsAsStudent Conversation[] @relation("ConversationStudent")
  conversationMessages   ConversationMessage[]
  conversationReports    ConversationReport[]

  @@map("users")
}

/// パスワード再設定トークン（単回利用・有効期限付き）
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ============================================================
// 先生プロフィール
// ============================================================

/// 先生のプロフィール（1ユーザーにつき1件）
model TeacherProfile {
  id                  String        @id @default(cuid())
  userId              String        @unique @map("user_id")
  slug                String        @unique // URL用の一意な識別子
  displayName         String        @map("display_name") // 表示名
  catchphrase         String?       @db.VarChar(100) // キャッチコピー
  bio                 String?       @db.Text // 自己紹介
  lessonContent       String?       @map("lesson_content") @db.Text // レッスン内容
  profileImageUrl     String?       @map("profile_image_url") // プロフィール写真URL
  youtubeUrl          String?       @map("youtube_url") // YouTube自己紹介動画URL（任意）
  websiteUrl          String?       @map("website_url") // ホームページURL（任意）
  snsUrl              String?       @map("sns_url") // SNSリンク（任意）
  // 連絡先情報（連絡先を購入した生徒にのみ開示。公開ページには出さない）
  phone               String?       @map("phone") // 電話番号（任意・購入者のみ開示）
  lineId              String?       @map("line_id") // LINE ID（任意・保存のみ／画面には表示しない）
  priceMin            Int?          @map("price_min") // 参考価格（下限・円）
  priceMax            Int?          @map("price_max") // 参考価格（上限・円）
  // 基本情報（任意・既存データは null のまま互換）
  gender              Gender? // 性別
  ageRange            AgeRange?     @map("age_range") // 年代
  teachingYears       Int?          @map("teaching_years") // 講師歴（年）
  /**
   * 指導方法（複数可）。UI・検索の主データ。
   * 旧 teachingMethod / isOnline から移行し、保存時に同期する。
   */
  teachingMethods     TeachingMethod[] @default([]) @map("teaching_methods")
  /** @deprecated 互換用。teachingMethods へ移行済みなら null 可 */
  teachingMethod      TeachingMethod? @map("teaching_method")
  targetAges          TargetAge[]   @map("target_ages") // 指導対象（複数可）
  skillLevels         SkillLevel[]  @map("skill_levels") // 対応レベル（複数可）
  isOnline            Boolean       @default(false) @map("is_online") // オンライン対応（互換・検索用）
  hasTrial            Boolean       @default(false) @map("has_trial") // 初回体験あり
  // 新規受付ON/OFF（生徒の受け入れ可否）
  isAcceptingStudents Boolean       @default(true) @map("is_accepting_students")
  isPublic            Boolean       @default(false) @map("is_public") // 公開・非公開
  /**
   * 本人確認済みフラグ（互換・検索高速化用）。
   * identityVerificationStatus === VERIFIED と常に同期する。
   */
  isVerified          Boolean       @default(false) @map("is_verified")
  /**
   * 本人確認集約ステータス（null = 未申請）。
   * 公開バッジ表示・管理画面・先生マイページの判定に使う。
   */
  identityVerificationStatus IdentityVerificationStatus? @map("identity_verification_status")
  status              ProfileStatus @default(DRAFT) // 審査ステータス
  // プロフィール完成率（0〜100）。入力済み項目数から算出しUIの促進に利用
  profileCompletion   Int           @default(0) @map("profile_completion")
  viewCount           Int           @default(0) @map("view_count") // 閲覧数
  // レビュー集計（承認済みレビューから再計算して保持。検索カードでの高速表示用）
  reviewCount         Int           @default(0) @map("review_count") // 承認済みレビュー件数
  ratingAverage       Float         @default(0) @map("rating_average") // 平均評価（0〜5）
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // --- リレーション ---
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories     TeacherCategory[] // 担当カテゴリー（中間テーブル経由）
  areas          TeacherArea[] // 対応地域
  reviews        Review[] // 受け取ったレビュー
  favoritedBy    Favorite[] // お気に入り登録された記録
  recentlyViewed RecentlyViewed[] // 生徒に閲覧された記録
  purchases      Purchase[] // 連絡先を購入された記録
  verification   IdentityVerification? // 本人確認申請
  conversations  Conversation[] // 事前相談・チャットスレッド

  // --- 検索用インデックス ---
  // 一覧・検索の基本条件（公開中 かつ 受付中）で頻繁に絞り込むため複合indexを用意
  @@index([isPublic, isAcceptingStudents])
  @@index([status, isPublic])
  @@index([isOnline]) // オンライン対応での絞り込み
  @@index([teachingMethod])
  @@index([gender])
  @@index([ageRange])
  @@index([teachingYears])
  @@index([priceMin]) // 参考価格（下限）での範囲検索・並び替え
  @@index([isVerified]) // 本人確認済みでの絞り込み（検索高速化）
  @@index([identityVerificationStatus])
  @@map("teacher_profiles")
}

/// 先生の対応地域（1先生が複数地域を登録可能）
model TeacherArea {
  id         String   @id @default(cuid())
  teacherId  String   @map("teacher_id")
  prefecture String // 都道府県
  city       String? // 市区町村（任意）
  createdAt  DateTime @default(now()) @map("created_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([prefecture])
  @@index([prefecture, city])
  @@map("teacher_areas")
}

// ============================================================
// 生徒プロフィール
// ============================================================

/// 生徒のプロフィール（1ユーザーにつき1件・非公開）
model StudentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  displayName       String   @map("display_name") // 表示名（ニックネーム）
  bio               String?  @db.Text // 自己紹介（任意）
  prefecture        String? // 居住都道府県（任意）
  avatarUrl         String?  @map("avatar_url") // プロフィール画像URL（任意）
  isOnlinePreferred Boolean  @default(false) @map("is_online_preferred") // オンライン希望
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests StudentCategory[] // 興味のあるカテゴリー（中間テーブル経由）

  @@map("student_profiles")
}

// ============================================================
// カテゴリー
// ============================================================

/// レッスンカテゴリー（管理画面から追加・編集可能）
model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teachers TeacherCategory[] // このカテゴリーに属する先生（中間テーブル経由）
  students StudentCategory[] // このカテゴリーに興味のある生徒（中間テーブル経由）

  @@map("categories")
}

/// 先生 × カテゴリー の中間テーブル（多対多）
model TeacherCategory {
  teacherId  String   @map("teacher_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  teacher  TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([teacherId, categoryId])
  @@index([categoryId])
  @@map("teacher_categories")
}

/// 生徒 × カテゴリー の中間テーブル（興味のあるカテゴリー・多対多）
model StudentCategory {
  studentId  String   @map("student_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  student  StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([studentId, categoryId])
  @@index([categoryId])
  @@map("student_categories")
}

// ============================================================
// レビュー・お気に入り・閲覧履歴
// ============================================================

/// 生徒が先生に投稿するレビュー（審査を経て公開）
model Review {
  id        String       @id @default(cuid())
  teacherId String       @map("teacher_id")
  studentId String       @map("student_id")
  rating    Int // 評価（1〜5）
  title     String       @db.VarChar(100) // レビュータイトル
  comment   String       @db.Text // レビュー本文
  status    ReviewStatus @default(PENDING) // 審査ステータス
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student User           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // 同一生徒が同一先生に複数レビューを投稿できないようにする
  @@unique([teacherId, studentId])
  @@index([teacherId, status])
  @@map("reviews")
}

/// 生徒のお気に入り先生
model Favorite {
  studentId String   @map("student_id")
  teacherId String   @map("teacher_id")
  createdAt DateTime @default(now()) @map("created_at")

  student User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([studentId, teacherId])
  @@index([teacherId])
  @@map("favorites")
}

/// 生徒が最近見た先生（マイページの「最近見た先生」用）
model RecentlyViewed {
  studentId String   @map("student_id")
  teacherId String   @map("teacher_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  student User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([studentId, teacherId])
  @@index([studentId, viewedAt])
  @@map("recently_viewed")
}

// ============================================================
// 決済（連絡先購入）
// ============================================================

/// 連絡先購入（先生1名につき固定料金）
model Purchase {
  id                String         @id @default(cuid())
  studentId         String         @map("student_id")
  teacherId         String         @map("teacher_id")
  amount            Int // 支払い金額（円）
  paymentMethod     PaymentMethod  @map("payment_method")
  status            PurchaseStatus @default(PENDING)
  contactRevealedAt DateTime?      @map("contact_revealed_at") // 連絡先を開放した日時

  // PayPal 用フィールド
  paypalOrderId String? @map("paypal_order_id")

  // 銀行振込 用フィールド
  bankTransferName String?   @map("bank_transfer_name") // 振込名義
  confirmedAt      DateTime? @map("confirmed_at") // 管理者が入金確認した日時
  confirmedBy      String?   @map("confirmed_by") // 確認した管理者のユーザーID

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@map("purchases")
}

// ============================================================
// お問い合わせ
// ============================================================

/// サイトへのお問い合わせ（ログイン不要でも送信可能）
model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String        @db.Text
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("inquiries")
}

// ============================================================
// 本人確認
// ============================================================

/// 先生の本人確認申請（1先生につき1件）
model IdentityVerification {
  id           String               @id @default(cuid())
  teacherId    String               @unique @map("teacher_id")
  documentType IdentityDocumentType @map("document_type")
  documentUrl  String               @map("document_url") // 提出書類（非公開・管理者のみ閲覧）
  note         String?              @db.Text // 先生からの備考（任意）
  status       VerificationStatus   @default(PENDING)
  rejectReason String?              @map("reject_reason") @db.Text // 却下理由
  reviewedAt   DateTime?            @map("reviewed_at")
  reviewedBy   String?              @map("reviewed_by") // 審査した管理者のユーザーID
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("identity_verifications")
}

// ============================================================
// 通知・お知らせ
// ============================================================

/// 特定ユーザー宛の通知
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType @default(SYSTEM)
  title     String
  body      String           @db.Text
  linkUrl   String?          @map("link_url") // 関連ページへのリンク（任意）
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

/// サイト全体向けのお知らせ（管理者が作成・トップページに表示）
model Announcement {
  id           String   @id @default(cuid())
  title        String
  content      String   @db.Text
  published    Boolean  @default(false)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([published, displayOrder])
  @@index([published, createdAt])
  @@map("announcements")
}

// ============================================================
// 事前相談 / チャット（Conversation 基盤）
// ------------------------------------------------------------
// 現在は PRE_CONSULTATION のみ。将来 CHAT タイプや MessageKind を
// 追加しても同一テーブルで拡張できる設計。
// ============================================================

/// 生徒↔先生の会話スレッド
model Conversation {
  id            String             @id @default(cuid())
  type          ConversationType   @default(PRE_CONSULTATION)
  status        ConversationStatus @default(OPEN)
  studentId     String             @map("student_id") // User.id（生徒）
  teacherId     String             @map("teacher_id") // TeacherProfile.id
  lastMessageAt DateTime?          @map("last_message_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  student  User                   @relation("ConversationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher  TeacherProfile         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]
  reports  ConversationReport[]

  @@unique([studentId, teacherId, type])
  @@index([teacherId, lastMessageAt])
  @@index([studentId, lastMessageAt])
  @@index([status])
  @@map("conversations")
}

/// 会話内メッセージ
model ConversationMessage {
  id             String            @id @default(cuid())
  conversationId String            @map("conversation_id")
  senderUserId   String            @map("sender_user_id")
  senderRole     MessageSenderRole @map("sender_role")
  kind           MessageKind       @default(TEXT)
  body           String            @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")

  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  reports      ConversationReport[]

  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@map("conversation_messages")
}

/// 送信時にブロックする NG ワード（管理画面で CRUD）
model NgWord {
  id        String         @id @default(cuid())
  word      String         @unique
  category  NgWordCategory
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([isActive, category])
  @@map("ng_words")
}

/// 相談・メッセージへの通報
model ConversationReport {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  messageId      String?      @map("message_id")
  reporterUserId String       @map("reporter_user_id")
  reason         String       @db.Text
  status         ReportStatus @default(NEW)
  adminNote      String?      @map("admin_note") @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  reporter     User                 @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([conversationId])
  @@map("conversation_reports")
}

// ============================================================
// サイト設定
// ============================================================

/// キー・バリュー形式のサイト設定
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
