# ===========================================
# チョコット先生 — 環境変数（.env.example）
# ===========================================
# 使い方: このファイルを .env にコピーし、値を設定してください。
#   cp .env.example .env
#
# 本番（Cloudflare Pages）では Cloudflare ダッシュボードの
# 「Settings → Environment variables」に同じキーを設定します。
# シークレット値は「Encrypt」にチェックを入れて保存してください。

# -------------------------------------------
# 必須 — データベース
# -------------------------------------------
# PostgreSQL 接続 URL（Prisma / Server Actions で使用）
# ローカル例:
#   postgresql://user:password@localhost:5432/chocotte_sensei?schema=public
# 本番例（Neon / Supabase / Railway 等）:
#   postgresql://user:pass@host/db?sslmode=require
#
# ★ Cloudflare Workers 本番では Prisma Accelerate が必須です ★
# Workers から直接 TCP 接続できないため、Accelerate の prisma:// URL を設定してください。
# ビルド時は prisma generate --no-engine を使用（query_engine WASM を Worker に含めない）
# 1. https://console.prisma.io で Accelerate を有効化
# 2. Cloudflare の DATABASE_URL に prisma://... を設定（Encrypt 必須）
# 3. ローカル開発は従来の postgresql:// のままで OK
# 代替: Cloudflare Hyperdrive + @prisma/adapter-pg（要 db.ts 改修）
DATABASE_URL="postgresql://user:password@localhost:5432/chocotte_sensei?schema=public"

# -------------------------------------------
# 必須 — NextAuth (Auth.js v5)
# -------------------------------------------
# 32バイト以上のランダム文字列（本番は必ず変更）
# 生成例: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# アプリの公開 URL（末尾スラッシュなし）
# ローカル: http://localhost:3000
# 本番:   https://chocotte-sensei.com
AUTH_URL="http://localhost:3000"

# Cloudflare / リバースプロキシ背後では true 推奨（auth.ts でも trustHost: true を設定済み）
# AUTH_TRUST_HOST="true"

# -------------------------------------------
# 必須（本番）— サイト URL
# -------------------------------------------
# constants/site.ts の SITE.url と一致させる本番ドメイン
# SEO（canonical / OGP / sitemap）に使用されます。
# コード内定数も本番ドメインに合わせて更新してください。
# NEXT_PUBLIC_ はクライアント公開用。現状は主にサーバー側 SITE 定数を使用。
# NEXT_PUBLIC_SITE_URL="https://chocotte-sensei.com"

# -------------------------------------------
# 任意 — PayPal（連絡先購入）
# -------------------------------------------
# 未設定時は「テストモード」（実請求なし）で動作します。
# 本番公開前に sandbox で動作確認後、live に切り替えてください。
# PAYPAL_MODE="sandbox"          # sandbox | live
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""

# -------------------------------------------
# 任意 — Node.js（Cloudflare ビルド）
# -------------------------------------------
# Cloudflare Pages の Environment variables で設定
# NODE_VERSION="20"

# -------------------------------------------
# 必須（プロフィール画像アップロード）— Cloudflare R2
# -------------------------------------------
# 1. Cloudflare ダッシュボードで R2 バケットを作成
#    バケット名: chocotte-sensei-profile-images（wrangler.jsonc と一致）
# 2. バケットの「公開アクセス」またはカスタムドメインを設定し、公開 URL を取得
# 3. wrangler.jsonc の vars.R2_PUBLIC_URL と .env の R2_PUBLIC_URL を同じ値に設定
# 4. ローカル開発（next dev）では wrangler の R2 バインディングが自動接続されます
#    （open-next.config.ts の initOpenNextCloudflareForDev 経由）
R2_PUBLIC_URL="https://pub-4c9f6da2da5842389e4fe7dc17303edd.r2.dev"

# -------------------------------------------
# 必須（パスワード再設定メール）— Resend
# -------------------------------------------
# Cloudflare Workers から fetch で送信（SMTP 不要）
# 1. https://resend.com で API キーを発行
# 2. 送信元ドメインを Resend で認証（または onboarding@resend.dev でテスト）
# 3. Cloudflare の RESEND_API_KEY は Encrypt 必須
RESEND_API_KEY=""
EMAIL_FROM="チョコット先生 <noreply@example.com>"
